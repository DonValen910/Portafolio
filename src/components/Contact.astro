---
import { value_web3form } from '../../data/value_web3form.js';
---

<section>
  <h2>Contacto</h2>

  <form id="form" action="https://api.web3forms.com/submit" method="POST">
    <input type="hidden" name="access_key" value={value_web3form} />
    <label for="name">Nombre:</label>
    <input type="text" id="name" name="name" required />

    <label for="email">Correo electrónico:</label>
    <input type="email" id="email" name="email" required />

    <label for="message">Mensaje:</label>
    <textarea id="message" name="message" rows="5" required></textarea>

    <button type="submit">Enviar</button>

    <div id="result"></div>
  </form>
</section>

<script is:inline>
  document.addEventListener(
    "DOMContentLoaded",
    () => {
      const form = document.getElementById("form");
      const result = document.getElementById("result");

      form.addEventListener("submit", function (e) {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.querySelectorAll(":invalid")[0].focus();
          return;
        }
        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        result.innerHTML = "Cargando...";

        fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: json,
        })
          .then(async (response) => {
            const text = await response.text();
            let data = {};

            try {
              data = text ? JSON.parse(text) : {};
            } catch {
              data = { message: text };
            }

            if (response.status == 200) {
              result.innerHTML =
                "Formulario enviado con éxito. Gracias por tu mensaje.";
            } else {
              console.log(response);
              result.innerHTML =
                data.error ||
                data.message ||
                "Formulario no enviado, por favor intente nuevamente.";
            }
          })
          .catch((error) => {
            console.log(error);
            result.innerHTML =
              "Formulario no enviado, por favor intente nuevamente.";
          })
          .then(function () {
            form.reset();
            setTimeout(() => {
              result.style.display = "none";
            }, 5000);
          });
      });
    },
    { once: true },
  );
</script>

<style>
  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;
    width: 100%;
  }

  label {
    font-weight: bold;
    color: var(--color-blanco);
  }

  input,
  textarea,
  button,
  label {
    font-size: 18px;
  }

  input,
  textarea {
    padding: 0.5rem;
    border: 1px solid var(--color-blanco);
    border-radius: 4px;
    background-color: transparent;
    color: var(--color-blanco);
    max-width: 100%;
  }

  textarea {
    resize: vertical;
    min-height: 100px;
    max-height: 300px;
  }

  button {
    padding: 0.5rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  button:hover {
    background: #ffa500;
    color: var(--color-oscuro);
  }
</style>
